import java.util.Scanner;

public class Main
{
	public static void main(String[] args) {
	    
		Scanner scanner = new Scanner(System.in);
		
		System.out.print("Digite a primeira nota: ");
		int nota1 = scanner.nextInt();
		
		System.out.print("Digite a segunda nota: ");
