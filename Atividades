import java.util.Scanner;

public class Main{
	public static void main(String[] args) {
		
		Scanner scanner = new Scanner (System.in);
		
		System.out.print("Digite o numero que voce quer consultar: ");
		int numero = scanner.nextInt();
		
		int n2 = numero * 2;
		int n3 = numero * 3;
		int n4 = numero * 4;
		
		System.out.println("O numero que voce escolheu foi o " +numero);
		System.out.println("Ele multiplicado por 1 e " +numero);
    	System.out.println("Ele multiplicado por 2 e " +n2);
	    System.out.println("Ele multiplicado por 3 e " +n3);
	    System.out.println("Ele multiplicado por 4 e " +n4);
	}
}

